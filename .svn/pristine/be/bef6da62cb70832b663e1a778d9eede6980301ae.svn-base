<%@ page language="java" contentType="text/html; charset=ISO-8859-1"
	pageEncoding="ISO-8859-1"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="ISO-8859-1">
<title>Asset Management</title>

<link href="pages/css/login.css" rel="stylesheet" type="text/css" />
<link href="assets/plugins/bootstrap4/css/bootstrap.min.css" rel="stylesheet" type="text/css">
<style>
body {
  background-color: #80ffff;
  background-image: linear-gradient(to right,#80ffff,#ba1e9b );
}
</style>
</head>
<body>
	
<div class="pt-5" > 
 <h1 align="center" >ASSET MANAGEMENT </h1>  
  <div class="global-container"> 
  
    <div class="card login-form">  
    <div class="card-body shadow p-4 m-2 bg-body rounded">  
        <h3 class="card-title text-center"> Login </h3>  
        <div class="card-text">  
            <form action="checkCredentials.htm" method="POST">  
                <div class="form-group">  
                    <label> USER ID </label>  
                    <input type="text" class="form-control form-control-sm"  id="userid" name="userid" autocomplete="off"  placeholder="User Id" required="required">  
                </div>  
                <div class="form-group">  
                    <label> Password </label>  
                   <input type="password" class="form-control form-control-sm" id="password" name="password" placeholder="Credentials" required="required">  
                </div>  
                <button type="submit" name="submit" class="btn btn-primary btn-block"> Sign in </button>   
            </form>  
        </div>  
    </div>  
</div>  
</div>  
</div>
	<!-- 	<label>User ID</label> 
		<input type="text" id="userid" name="userid"
			autocomplete="off" autofocus="autofocus" placeholder="User Id"
			required="required" /> 
		<label>Password</label>
		 <input type="password" class="form-control" id="password" name="password"
			placeholder="Credentials" required="required" />

		<button type="submit" name="submit">Sign in</button> -->

</body>
</html>